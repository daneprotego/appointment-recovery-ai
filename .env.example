# App
# Use the deployed HTTPS URL in production, for example https://appointment-recovery-ai.vercel.app.
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Replace these safe placeholders with values from Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-me-supabase-service-role-key

# Scheduled jobs
# Use a long random value in production and send it as the x-job-secret header.
REMINDER_JOB_SECRET=replace-me-long-random-job-secret

# Twilio
TWILIO_ACCOUNT_SID=replace-me-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-me-twilio-auth-token
TWILIO_SMS_FROM_NUMBER=+15555550100
TWILIO_SMS_ENABLED=false
TWILIO_VALIDATE_WEBHOOK_SIGNATURES=false

# OpenAI
OPENAI_API_KEY=replace-me-openai-api-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace-me-stripe-publishable-key
STRIPE_SECRET_KEY=replace-me-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-me-stripe-webhook-secret
STRIPE_STARTER_PRICE_ID=replace-me-starter-price-id
STRIPE_GROWTH_PRICE_ID=replace-me-growth-price-id
STRIPE_PRO_PRICE_ID=replace-me-pro-price-id

# Calendar integrations
GOOGLE_CALENDAR_CLIENT_ID=replace-me-google-calendar-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=replace-me-google-calendar-client-secret
MICROSOFT_CALENDAR_CLIENT_ID=replace-me-microsoft-calendar-client-id
MICROSOFT_CALENDAR_CLIENT_SECRET=replace-me-microsoft-calendar-client-secret
